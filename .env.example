# ── Optional API Keys ──────────────────────────────────────────────────────────
# Modules work without keys but may be rate-limited on free tiers.

# OpenCorporates — https://opencorporates.com/api_accounts/new
OPENCORPORATES_API_KEY=

# Shodan — https://account.shodan.io (future module)
SHODAN_API_KEY=

# SecurityTrails — https://securitytrails.com/app/account/credentials (future module)
SECURITYTRAILS_API_KEY=

# ── Application ────────────────────────────────────────────────────────────────
# Set a secret for session signing (any random string)
SECRET_KEY=change-me-before-production

# Data retention: days to keep audit logs (0 = keep forever)
AUDIT_LOG_RETENTION_DAYS=90
